{
  "name": "coursera-deadline-tracker",
  "private": true,
  "workspaces": [
    "worker",
    "extension"
  ],
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "(cd worker && bun test) && (cd extension && bun test)",
    "typecheck:worker": "bunx tsc -p worker/tsconfig.json --noEmit",
    "typecheck:extension": "bunx tsc -p extension/tsconfig.json --noEmit",
    "typecheck": "bun run typecheck:worker && bun run typecheck:extension",
    "build:extension": "(cd extension && bun run build)",
    "release": "bun run scripts/release-extension.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{ts,tsx,js,jsx}": "oxlint"
  },
  "packageManager": "bun@1.3.9"
}
